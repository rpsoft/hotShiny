library(hotShiny)
ui <- function() {
div(
h1("Basic HotShiny App"),
textInput("name", "Enter your name:"),
textOutput("greeting")
)
}
server <- function(input, output, session) {
# Reactive expression
greeting <- reactive({
paste("Hello,", input$name, "!")
})
# Render output
output$greeting <- renderText({
greeting()
})
}
# Create and run app
app_obj <- app(ui, server)
# Run app
app_obj$runApp()
library(shiny); source('tests/examples/basic-app.R')
